{
  "name": "saas-office-erp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "postinstall": "pnpm --filter @saas/database generate",
    "build:packages": "pnpm --filter @saas/types build && pnpm --filter @saas/database build",
    "build": "pnpm build:packages && pnpm --filter api build && pnpm --filter web build",
    "build:web": "pnpm build:packages && pnpm --filter web build",
    "build:api": "pnpm build:packages && pnpm --filter api build",
    "typecheck": "pnpm --filter @saas/database typecheck && pnpm --filter api exec tsc --noEmit",
    "db:generate": "pnpm --filter @saas/database generate",
    "db:migrate": "pnpm --filter @saas/database migrate",
    "db:deploy": "pnpm --filter @saas/database migrate:deploy",
    "db:studio": "pnpm --filter @saas/database studio",
    "db:seed": "pnpm --filter @saas/database seed"
  },
  "devDependencies": {
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
