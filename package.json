{
  "name": "saas-office-erp",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev:web": "pnpm --filter web dev",
    "dev:api": "pnpm --filter api dev",
    "postinstall": "pnpm --filter @saas/database generate",
    "build": "pnpm --filter @saas/database generate && pnpm --filter @saas/types build && pnpm --filter api build && pnpm --filter web build",
    "db:generate": "pnpm --filter @saas/database generate",
    "db:push": "pnpm --filter @saas/database push",
    "db:seed": "pnpm --filter @saas/database seed"
  },
  "dependencies": {
    "next": "^14.2.3"
  },
  "devDependencies": {
    "next": "^14.2.3",
    "typescript": "^5.3.3"
  }
}
