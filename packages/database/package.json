{
  "name": "@saas/database",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "postinstall": "prisma generate",
    "generate": "prisma generate",
    "migrate": "prisma migrate dev",
    "migrate:deploy": "prisma migrate deploy",
    "studio": "prisma studio",
    "seed": "ts-node --transpile-only src/seed.ts",
    "build:sql": "ts-node --transpile-only scripts/build-setup-sql.ts",
    "typecheck": "tsc --noEmit"
  },
  "prisma": {
    "seed": "ts-node --transpile-only src/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "bcryptjs": "^2.4.3"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.17.10",
    "prisma": "^5.22.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2"
  }
}
