enable-prepost-scripts=true

# Flat node_modules instead of pnpm's symlinked store.
#
# Vercel's serverless bundler traces required files from disk; it does not
# follow pnpm's symlink layout reliably, and the casualty is always the same —
# the Prisma query engine binary is left out of the bundle and every request
# dies with "Query engine binary could not be found", surfaced only as
# FUNCTION_INVOCATION_FAILED. Hoisting costs some disk and buys a deployable
# function.
node-linker=hoisted
