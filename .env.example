# =============================================================================
#  Office ERP — Environment Template
#  Copy to `.env` and fill in. NEVER commit `.env`.
# =============================================================================

# --- Database -----------------------------------------------------------------
# Neon / Supabase pooled connection string.
# Neon:     postgresql://USER:PASS@ep-xxx-pooler.REGION.aws.neon.tech/DB?sslmode=require
# Supabase: postgresql://postgres.REF:PASS@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Direct (non-pooled) connection — required by `prisma migrate`.
# On Neon this is the same host WITHOUT `-pooler`. On Supabase use port 5432.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# --- API ----------------------------------------------------------------------
NODE_ENV=development
API_PORT=4000
API_PREFIX=api/v1

# --- Auth ---------------------------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
# These MUST be different from each other and MUST be rotated per environment.
JWT_ACCESS_SECRET=CHANGE_ME_generate_a_48_byte_random_string
JWT_REFRESH_SECRET=CHANGE_ME_generate_a_DIFFERENT_48_byte_random_string
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d

# Account lockout after N consecutive failed logins
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCKOUT_MINUTES=15

# --- CORS ---------------------------------------------------------------------
# Comma-separated. Never use "*" — credentials are sent cross-origin.
CORS_ORIGINS=http://localhost:3000

# --- Rate limiting ------------------------------------------------------------
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=120
THROTTLE_AUTH_LIMIT=10

# --- File storage (S3-compatible: AWS S3, Cloudflare R2, MinIO) ----------------
STORAGE_DRIVER=local
STORAGE_LOCAL_PATH=./storage
S3_ENDPOINT=
S3_REGION=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
# Max upload size in bytes (10 MB)
UPLOAD_MAX_BYTES=10485760

# --- Frontend -----------------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1

# --- Email (Phase 8) ----------------------------------------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="Office ERP <no-reply@example.com>"

# --- WhatsApp (Phase 8) -------------------------------------------------------
WHATSAPP_PROVIDER=meta
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

# --- AI (Phase 9) -------------------------------------------------------------
ANTHROPIC_API_KEY=
AI_MODEL=claude-sonnet-5
